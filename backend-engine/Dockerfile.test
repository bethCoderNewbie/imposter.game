FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml ./
COPY backend-engine/ ./backend-engine/
COPY docs/architecture/roles.json ./docs/architecture/roles.json
COPY puzzles.md ./puzzles.md

# Install test extras (fakeredis, pytest-asyncio, pytest-mock, etc.)
RUN pip install --no-cache-dir -e ".[test]"

CMD ["pytest", "backend-engine/tests/", "-v", "--tb=short", "--timeout=30"]
