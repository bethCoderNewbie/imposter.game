# Ensure shell scripts and Docker-related files always use LF in the repo,
# regardless of the developer's OS. CRLF in a shebang breaks exec in Linux containers.
*.sh        text eol=lf
Dockerfile* text eol=lf
*.conf      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
