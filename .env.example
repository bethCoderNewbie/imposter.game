# Werewolf Game Server — Environment Variables
# Copy to .env and fill in SECRET_KEY before running:
#   cp .env.example .env

# ── REQUIRED ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-at-least-32-random-characters

# ── Redis ─────────────────────────────────────────────────────────────────────
# Docker Compose service name: redis
# Local dev: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ── Schema ────────────────────────────────────────────────────────────────────
SCHEMA_VERSION=0.4

# ── Phase timers (seconds) ────────────────────────────────────────────────────
NIGHT_TIMER_SECONDS=60
DAY_TIMER_SECONDS=180
VOTE_TIMER_SECONDS=90
ROLE_DEAL_TIMER_SECONDS=30
HUNTER_PENDING_TIMER_SECONDS=30

# ── Logging ───────────────────────────────────────────────────────────────────
DEBUG=false
