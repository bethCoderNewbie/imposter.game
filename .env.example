# Werewolf Game Server — Environment Variables
#
# FIRST-TIME SETUP (run once before anything else):
#   python -m venv .venv
#   source .venv/Scripts/activate          # Bash
#   .\.venv\Scripts\Activate.ps1           # PowerShell
#   pip install -e ".[dev,test]"
#
# Then copy this file and set SECRET_KEY:
#   cp .env.example .env

# ── REQUIRED ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-at-least-32-random-characters

# ── Redis ─────────────────────────────────────────────────────────────────────
# Docker Compose service name: redis
# Local dev: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ── Schema ────────────────────────────────────────────────────────────────────
SCHEMA_VERSION=0.4

# ── Phase timers (seconds) ────────────────────────────────────────────────────
NIGHT_TIMER_SECONDS=60
DAY_TIMER_SECONDS=180
VOTE_TIMER_SECONDS=90
ROLE_DEAL_TIMER_SECONDS=30
HUNTER_PENDING_TIMER_SECONDS=30

# ── Logging ───────────────────────────────────────────────────────────────────
DEBUG=false

# ── Hybrid deployment (local backend + Vercel frontend) ──────────────────────
# Leave all three blank for pure LAN mode (all traffic stays on local network).
#
# cloudflared starts with every `docker compose up`. If CLOUDFLARE_TUNNEL_TOKEN is
# blank, cloudflared exits on its own — other services are unaffected.
#
# Get a token: dash.cloudflare.com > Zero Trust > Networks > Tunnels > Create tunnel
# Ephemeral Quick Tunnel (no account needed — URL printed in logs):
#   docker compose --profile tunnel-quick up

# Token from: cloudflared tunnel token <tunnel-name>
CLOUDFLARE_TUNNEL_TOKEN=

# Public HTTPS URL exposing this backend (tunnel, ngrok, port-forward, etc.)
# Used for three things:
#   1. Display Docker build → VITE_QR_BACKEND_URL → embedded in QR ?b= param
#   2. Backend runtime → BACKEND_PUBLIC_URL → photo and TTS URLs returned as absolute
#   3. Set as VITE_BACKEND_URL in Vercel project env vars for mobile and display
# Example: https://backend.imposter.com
BACKEND_URL=

# Vercel URL of the mobile frontend.
# When set, the QR code points here instead of the local LAN IP.
# Example: https://my-werewolf-game.vercel.app
MOBILE_URL=

# ── Narrator / LLM-TTS (PRD-008) ────────────────────────────────────────────
# Ollama runs as a Docker Compose service (no host install needed).
# Model is pulled automatically on first `docker compose up` via the ollama-pull service.
NARRATOR_ENABLED=false
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
KOKORO_URL=http://tts:8880
NARRATOR_VOICE=af_bella
NARRATOR_MODE=prebaked
